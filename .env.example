# Upload constraints
MAX_UPLOAD_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
MIN_IMAGE_DIMENSION=480

# OCR
OCR_ENGINE=tesseract          # tesseract | easyocr
TESSERACT_LANG=eng
LOW_CONFIDENCE_THRESHOLD=70

# Logging
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs
LOG_JSON=true

# Server
CORS_ORIGINS=*
